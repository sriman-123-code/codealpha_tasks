void loginUser() {
    string username, password, u, p;
    cout << "\n--- Login ---\n";
    cout << "Enter username: ";
    cin >> username;
    cout << "Enter password: ";
    cin >> password;

    ifstream fin(username + ".txt");
    if (!fin.is_open()) {
        cout << "Error: User not found.\n";
        return;
    }

    fin >> u >> p;
    fin.close();

    if (u == username && p == hashPassword(password))
        cout << "Login successful.\n";
    else
        cout << "Invalid password.\n";
}

