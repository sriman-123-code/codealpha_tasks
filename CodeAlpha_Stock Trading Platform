import java.util.*;

class Stock {
    String name;
    double price;

    Stock(String name, double price) {
        this.name = name;
        this.price = price;
    }
}

public class Main {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        Map<String, Stock> stocks = new HashMap<>();
        stocks.put("TCS", new Stock("TCS", 3500));
        stocks.put("INFY", new Stock("INFY", 1500));
        stocks.put("RELIANCE", new Stock("RELIANCE", 2800));

        Map<String, Integer> portfolio = new HashMap<>();
        double balance = 100000;

        while (true) {
            System.out.println("\n===== STOCK TRADING PLATFORM =====");
            System.out.println("1. Buy Stock");
            System.out.println("2. Sell Stock");
            System.out.println("3. View Portfolio");
            System.out.println("4. Exit");
            System.out.print("Enter Choice: ");

            int choice = sc.nextInt();

            switch (choice) {

                case 1:
                    System.out.println("\nAvailable Stocks:");
                    for (Stock s : stocks.values()) {
                        System.out.println(s.name + " - Rs." + s.price);
                    }

                    System.out.print("Enter Stock Name: ");
                    String buyStock = sc.next().toUpperCase();

                    if (!stocks.containsKey(buyStock)) {
                        System.out.println("Invalid Stock!");
                        break;
                    }

                    System.out.print("Enter Quantity: ");
                    int buyQty = sc.nextInt();

                    double cost = buyQty * stocks.get(buyStock).price;

                    if (cost <= balance) {
                        balance -= cost;
                        portfolio.put(buyStock,
                                portfolio.getOrDefault(buyStock, 0) + buyQty);
                        System.out.println("Stock Purchased Successfully!");
                    } else {
                        System.out.println("Insufficient Balance!");
                    }
                    break;

                case 2:
                    System.out.print("Enter Stock Name: ");
                    String sellStock = sc.next().toUpperCase();

                    if (!portfolio.containsKey(sellStock)) {
                        System.out.println("You don't own this stock!");
                        break;
                    }

                    System.out.print("Enter Quantity to Sell: ");
                    int sellQty = sc.nextInt();

                    int owned = portfolio.get(sellStock);

                    if (sellQty <= owned) {
                        balance += sellQty * stocks.get(sellStock).price;
                        portfolio.put(sellStock, owned - sellQty);
                        System.out.println("Stock Sold Successfully!");
                    } else {
                        System.out.println("Not Enough Shares!");
                    }
                    break;

                case 3:
                    System.out.println("\n===== PORTFOLIO =====");

                    for (String key : portfolio.keySet()) {
                        System.out.println(key + " : " + portfolio.get(key) + " shares");
                    }

                    System.out.println("Balance : Rs." + balance);
                    break;

                case 4:
                    System.out.println("Thank You For Using Stock Trading Platform");
                    return;

                default:
                    System.out.println("Invalid Choice!");
            }
        }
    }
}
