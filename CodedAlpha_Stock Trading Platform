import java.util.Scanner;

class Stock {
    String name;
    int price;
    int quantity;

    Stock(String name, int price) {
        this.name = name;
        this.price = price;
        this.quantity = 0;
    }
}

class User {
    String name;

    User(String name) {
        this.name = name;
    }
}

class Transaction {
    String stockName;
    int quantity;
    String type;

    Transaction(String stockName, int quantity, String type) {
        this.stockName = stockName;
        this.quantity = quantity;
        this.type = type;
    }
}

public class StockTradingPlatform {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        User user = new User("Investor");

        Stock[] stocks = {
            new Stock("TCS", 3500),
            new Stock("Infosys", 1500),
            new Stock("Wipro", 500)
        };

        while (true) {

            System.out.println("\n===== STOCK TRADING PLATFORM =====");
            System.out.println("User : " + user.name);
            System.out.println("1. View Market Data");
            System.out.println("2. Buy Stock");
            System.out.println("3. Sell Stock");
            System.out.println("4. View Portfolio");
            System.out.println("5. Exit");
            System.out.print("Enter Choice: ");

            int choice = sc.nextInt();

            switch (choice) {

                case 1:
                    System.out.println("\nMarket Data");
                    for (int i = 0; i < stocks.length; i++) {
                        System.out.println((i + 1) + ". "
                                + stocks[i].name
                                + " - Rs." + stocks[i].price);
                    }
                    break;

                case 2:
                    System.out.print("Enter Stock Number: ");
                    int buy = sc.nextInt();

                    System.out.print("Enter Quantity: ");
                    int qty = sc.nextInt();

                    stocks[buy - 1].quantity += qty;

                    Transaction buyTran =
                            new Transaction(stocks[buy - 1].name,
                                    qty, "BUY");

                    System.out.println("Transaction: "
                            + buyTran.type + " "
                            + buyTran.quantity + " Shares of "
                            + buyTran.stockName);

                    System.out.println("Stock Purchased Successfully");
                    break;

                case 3:
                    System.out.print("Enter Stock Number: ");
                    int sell = sc.nextInt();

                    System.out.print("Enter Quantity: ");
                    qty = sc.nextInt();

                    if (stocks[sell - 1].quantity >= qty) {

                        stocks[sell - 1].quantity -= qty;

                        Transaction sellTran =
                                new Transaction(stocks[sell - 1].name,
                                        qty, "SELL");

                        System.out.println("Transaction: "
                                + sellTran.type + " "
                                + sellTran.quantity + " Shares of "
                                + sellTran.stockName);

                        System.out.println("Stock Sold Successfully");

                    } else {
                        System.out.println("Insufficient Shares");
                    }
                    break;

                case 4:

                    int totalValue = 0;

                    System.out.println("\n===== PORTFOLIO =====");

                    for (Stock s : stocks) {

                        System.out.println(
                                s.name + " : "
                                        + s.quantity + " Shares");

                        totalValue += s.quantity * s.price;
                    }

                    System.out.println(
                            "Portfolio Value = Rs." + totalValue);

                    break;

                case 5:
                    System.out.println("Thank You");
                    System.exit(0);

                default:
                    System.out.println("Invalid Choice");
            }
        }
    }
}
